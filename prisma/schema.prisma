// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANT CORE
// Every row in every table is scoped to a Tenant
// ─────────────────────────────────────────────

model Tenant {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique   // used in URL / subdomain
  plan        Plan       @default(FREE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // AI configuration
  aiProvider     AiProvider @default(GEMINI)
  dailyAiUsage   Int        @default(0)
  dailyAiLimit   Int        @default(50)
  lastUsageReset DateTime   @default(now())

  // Relations
  users       User[]
  customers   Customer[]
  tickets     Ticket[]
  messages    Message[]
  apiKeys     ApiKey[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique     // Clerk user ID
  email        String   @unique
  name         String?
  avatarUrl    String?
  role         Role     @default(AGENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Multi-tenant foreign key (data isolation)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  assignedTickets Ticket[] @relation("AssignedAgent")
  messages        Message[]

  @@index([tenantId])
  @@index([clerkId])
  @@map("users")
}

model Customer {
  id          String   @id @default(cuid())
  email       String
  name        String
  phone       String?
  metadata    Json?    // flexible extra data per tenant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant foreign key (data isolation)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  tickets     Ticket[]

  @@unique([tenantId, email])   // email unique per tenant, not globally
  @@index([tenantId])
  @@map("customers")
}

model Ticket {
  id             String       @id @default(cuid())
  ticketNumber   Int          @default(autoincrement())
  subject        String
  description    String       @db.Text
  status         TicketStatus @default(OPEN)
  priority       Priority     @default(MEDIUM)
  channel        Channel      @default(EMAIL)
  tags           String[]
  metadata       Json?

  // AI-generated fields
  aiSuggestedResponse String?   @db.Text
  aiPriority          Priority?
  aiAnalyzedAt        DateTime?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  resolvedAt     DateTime?

  // Multi-tenant foreign key (data isolation)
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])

  assignedAgentId String?
  assignedAgent   User?       @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  messages        Message[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([customerId])
  @@map("tickets")
}

model Message {
  id          String      @id @default(cuid())
  body        String      @db.Text
  senderRole  SenderRole  @default(USER)
  isFromAgent Boolean     @default(false)   // false = customer, true = agent/AI
  isAiGenerated Boolean   @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Multi-tenant foreign key (data isolation)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  ticketId    String
  ticket      Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId    String?     // null = customer message
  author      User?       @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([ticketId])
  @@map("messages")
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique   // store hashed key only
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  // Multi-tenant foreign key (data isolation)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AiProvider {
  GEMINI
  GROQ
  MISTRAL
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Channel {
  EMAIL
  CHAT
  PHONE
  SOCIAL
  API
}

enum SenderRole {
  USER    // Customer message
  AGENT   // Agent reply
  SYSTEM  // Audit / system event
}
