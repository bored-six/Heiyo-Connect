# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# PostgreSQL connection string.
# Local: postgresql://user:password@localhost:5432/heiyo_connect
# Hosted: use Neon (neon.tech) free tier → Connection string from dashboard
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/heiyo_connect"

# ─────────────────────────────────────────────────────────────────────────────
# CLERK — Authentication
# Create a project at clerk.com → API Keys → copy both keys
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs — leave as-is for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# At least one AI key is required. Gemini is the default.
# Tenants can switch providers from Settings → AI Provider.
#
# Gemini: aistudio.google.com → Get API key (free tier available)
# Groq:   console.groq.com → API Keys (free tier, very fast)
# Mistral: console.mistral.ai → API Keys
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# MISTRAL_API_KEY=your_mistral_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# APP
# Base URL — used for absolute URLs in emails and public links
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# PUSHER — Real-time notifications (optional but recommended)
# Create a free app at pusher.com → Channels → App Keys
# If omitted, real-time toast notifications are disabled (Socket.io still works)
# ─────────────────────────────────────────────────────────────────────────────
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=us2
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ─────────────────────────────────────────────────────────────────────────────
# DEMO SEEDING
# After copying this file to .env and filling in the values, run:
#   pnpm db:push    → creates schema
#   pnpm db:seed    → seeds 3 demo tenants with 50+ tickets
# Demo login is created automatically by the seed script.
# ─────────────────────────────────────────────────────────────────────────────
